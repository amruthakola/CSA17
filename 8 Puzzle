from collections import deque

start = (1,2,3,4,0,5,6,7,8)
goal = (1,2,3,4,5,6,7,8,0)

moves = {
    0:[1,3],1:[0,2,4],2:[1,5],
    3:[0,4,6],4:[1,3,5,7],5:[2,4,8],
    6:[3,7],7:[4,6,8],8:[5,7]
}

queue = deque([(start, [])])
visited = set()

while queue:
    state, path = queue.popleft()

    if state == goal:
        print("Solved!")
        print(path + [state])
        break

    if state in visited:
        continue

    visited.add(state)

    blank = state.index(0)

    for m in moves[blank]:
        s = list(state)
        s[blank], s[m] = s[m], s[blank]
        queue.append((tuple(s), path + [state]))
